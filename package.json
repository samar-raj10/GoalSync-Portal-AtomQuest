{
  "name": "goalsync-portal",
  "version": "1.0.0",
  "private": true,
  "description": "GoalSync Portal full-stack employee goal setting and quarterly tracking system.",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/src/index.js",
    "server:start": "node server/src/index.js",
    "client:dev": "vite --host 0.0.0.0 --config client/vite.config.js",
    "client:build": "vite build --config client/vite.config.js",
    "seed": "node server/src/seed.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "daisyui": "^4.12.24",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "postcss": "^8.4.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.12",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
